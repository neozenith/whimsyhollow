name: Terraform CICD - {{ stack_name }}

# AUTO-GENERATED by the `tfs` CLI (tfs create) — per-stack caller for the reusable
# .github/workflows/terraform-cicd-per-stack.yml. Routing (which env an event
# applies to) lives in the reusable workflow; this file only wires the triggers +
# path filter for THIS stack and forwards the stack name.
#
# Regenerate / verify the full set with:
#   tfs gha-check        (or: uv run --frozen --directory infra/tfs tfs gha-check)

on:
  pull_request:
    types: [opened, synchronize, reopened, ready_for_review, converted_to_draft]
    paths:
      - 'infra/stacks/{{ stack_name }}/**'
      - 'infra/modules/**'
      - '.github/workflows/terraform-cicd-stack-{{ stack_name }}.yml'
      - '.github/workflows/terraform-cicd-per-stack.yml'
      - '.github/actions/terraform/**'
  push:
    branches: [main]
    tags: ['v*']
    paths:
      - 'infra/stacks/{{ stack_name }}/**'
      - 'infra/modules/**'
      - '.github/workflows/terraform-cicd-stack-{{ stack_name }}.yml'
      - '.github/workflows/terraform-cicd-per-stack.yml'
      - '.github/actions/terraform/**'
  workflow_dispatch:

permissions:
  contents: write          # diagram job pushes the rendered PNG to the ci-diagrams branch
  id-token: write          # required by google-github-actions/auth (OIDC)
  pull-requests: write

concurrency:
  group: terraform-{{ stack_name }}-{% raw %}${{ github.ref }}{% endraw %}
  cancel-in-progress: false

jobs:
  terraform:
    uses: ./.github/workflows/terraform-cicd-per-stack.yml
    with:
      stack: {{ stack_name }}
    secrets: inherit
